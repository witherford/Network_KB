# --- Secrets / credentials -------------------------------------------------
# The GitHub PAT lives one level up from this repo (in the OneDrive parent
# folder). Belt-and-braces: never accept a *.pat file inside the repo even
# if someone moves the token here by accident.
*.pat
*.token
.env
.env.*
!.env.example
*.secret
secrets.*
credentials.*

# --- Editor / IDE state ----------------------------------------------------
# Claude Code project preferences. settings.local.json logs every Bash
# invocation including arguments — this is what caused the original
# secret-scanning alert. Never commit it.
.claude/
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Build / OS / temp -----------------------------------------------------
node_modules/
*.log
*.bak
*.tmp

# --- Local-only push helpers (each one self-deletes after use, but in case
#     a run is interrupted, don't accidentally commit the WIP) -------------
scripts/push-*.mjs
!scripts/push-fixes.mjs
